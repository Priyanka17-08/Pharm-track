{
  "entities": {
    "Medicine": {
      "title": "Medicine",
      "description": "A medicine in the pharmacy inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "batch_number": { "type": "string" },
        "expiry_date": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "mrp": { "type": "number" },
        "supplier_info": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "batch_number", "expiry_date", "quantity", "price", "mrp"]
    },
    "Bill": {
      "title": "Bill",
      "description": "A sales bill",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_phone": { "type": "string" },
        "items": { "type": "array" },
        "total_amount": { "type": "number" },
        "payment_method": { "type": "string" }
      },
      "required": ["id", "date", "items", "total_amount"]
    }
  },
  "firestore": {
    "/users/{userId}/medicines/{medicineId}": {
      "schema": { "$ref": "#/entities/Medicine" },
      "description": "Medicines owned by a specific user (pharmacy owner)"
    },
    "/users/{userId}/bills/{billId}": {
      "schema": { "$ref": "#/entities/Bill" },
      "description": "Bills generated by a specific user (pharmacy owner)"
    }
  }
}
